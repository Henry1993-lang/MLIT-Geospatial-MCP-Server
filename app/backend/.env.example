# LLM API Keys
# Gemini未設定でもモックデータで起動できます。
GEMINI_API_KEY=
# 混雑時に別モデルへ切り替えたい場合だけ変更してください。
GEMINI_MODEL=gemini-2.5-flash

# MCP Server 起動設定
# app/backend から見た相対パスです。
# ルート直下に mlit-geospatial-mcp を clone した場合はこのまま使えます。
MCP_SERVER_COMMAND=../../mlit-geospatial-mcp/.venv/bin/python
MCP_SERVER_ARGS=../../mlit-geospatial-mcp/src/server.py

# 不動産情報ライブラリ APIキー
# 未設定の場合はアプリ側がモックデータで動作します。
LIBRARY_API_KEY=
